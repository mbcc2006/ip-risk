# Collector configuration — copy to `.env` (gitignored) and fill in.
# badip_logger.py reads these from the environment (or this .env file beside it).

BADIP_DB_HOST=10.0.0.5
BADIP_DB_PORT=3306
BADIP_DB_USER=badip
BADIP_DB_PASSWORD=change-me
BADIP_DB_NAME=security

# Optional overrides:
# REPORTER_IP=203.0.113.10        # this machine's public IP (default: auto-detect)
# CADDYFILE=/etc/caddy/Caddyfile  # where to discover Caddy access-log paths
# BADIP_ENV_FILE=/path/to/.env    # alternate path to this env file
